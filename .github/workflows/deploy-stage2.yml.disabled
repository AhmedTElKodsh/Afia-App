name: Deploy Stage 2 (Local Model + LLM Fallback)

# ⚠️ WARNING: Stage 2 local model implementation is not yet complete
# This workflow is configured but will fail until local model code is implemented
# See: src/services/localModel/README.md for implementation checklist

on:
  push:
    branches: [local-model]
  pull_request:
    branches: [local-model]

jobs:
  test:
    name: Run Tests (Stage 2)
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4

      - name: Validate required secrets
        run: |
          if [ -z "${{ secrets.VITE_ADMIN_PASSWORD }}" ]; then
            echo "❌ ERROR: VITE_ADMIN_PASSWORD secret is required but not set"
            echo "Please set it in repository settings: Settings > Secrets and variables > Actions"
            exit 1
          fi
          echo "✅ Required secrets validated"

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: 'npm'

      - name: Install dependencies
        run: npm ci

      - name: Run unit tests (including local model tests)
        run: npm run test
        env:
          STAGE: 'stage2'

      - name: Install Playwright browsers
        run: npx playwright install --with-deps chromium

      - name: Build for E2E tests (Stage 2)
        run: npm run build
        env:
          VITE_PROXY_URL: ${{ secrets.CLOUDFLARE_WORKER_URL_STAGE2 || 'https://afia-worker-stage2.savola.workers.dev' }}
          VITE_ADMIN_PASSWORD: ${{ secrets.VITE_ADMIN_PASSWORD }}
          VITE_STAGE: 'stage2'
          VITE_ENABLE_LOCAL_MODEL: 'true'

      - name: Run E2E tests (functional + local model)
        run: npx playwright test tests/e2e/
        env:
          CI: true
          VITE_ADMIN_PASSWORD: ${{ secrets.VITE_ADMIN_PASSWORD }}
          VITE_STAGE: 'stage2'
          VITE_ENABLE_LOCAL_MODEL: 'true'

      - name: Upload test results
        if: failure()
        uses: actions/upload-artifact@v4
        with:
          name: test-results-stage2
          path: |
            playwright-report/
            test-results/
          retention-days: 7

  deploy-worker-stage2:
    name: Deploy Worker (Stage 2 - Hybrid)
    runs-on: ubuntu-latest
    needs: test
    if: github.ref == 'refs/heads/local-model' && github.event_name == 'push'

    steps:
      - uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: 'npm'

      - name: Install Worker dependencies
        run: cd worker && npm ci

      - name: Apply KV namespace IDs to wrangler.toml
        run: bash scripts/apply-wrangler-kv-ids.sh
        env:
          CLOUDFLARE_RATE_LIMIT_KV_ID: ${{ secrets.CLOUDFLARE_RATE_LIMIT_KV_ID }}
          CLOUDFLARE_RATE_LIMIT_KV_PREVIEW_ID: ${{ secrets.CLOUDFLARE_RATE_LIMIT_KV_PREVIEW_ID }}

      - name: Sync admin password secret to Worker
        run: cd worker && echo "${{ secrets.VITE_ADMIN_PASSWORD }}" | npx wrangler secret put ADMIN_PASSWORD --env stage2
        env:
          CLOUDFLARE_API_TOKEN: ${{ secrets.CLOUDFLARE_API_TOKEN }}
          CLOUDFLARE_ACCOUNT_ID: ${{ secrets.CLOUDFLARE_ACCOUNT_ID }}

      - name: Deploy Worker (Stage 2)
        uses: nick-fields/retry-action@v3
        with:
          timeout_minutes: 10
          max_attempts: 5
          retry_wait_seconds: 30
          exponential_backoff: true
          command: cd worker && npx wrangler deploy --env stage2
        env:
          CLOUDFLARE_API_TOKEN: ${{ secrets.CLOUDFLARE_API_TOKEN }}
          CLOUDFLARE_ACCOUNT_ID: ${{ secrets.CLOUDFLARE_ACCOUNT_ID }}

  deploy-pages-stage2:
    name: Deploy Pages (Stage 2)
    runs-on: ubuntu-latest
    needs: test
    if: github.ref == 'refs/heads/local-model' && github.event_name == 'push'

    steps:
      - uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: 'npm'

      - name: Install dependencies
        run: npm ci

      - name: Build PWA (Stage 2 - with local model)
        run: npm run build
        env:
          VITE_PROXY_URL: ${{ secrets.CLOUDFLARE_WORKER_URL_STAGE2 || 'https://afia-worker-stage2.savola.workers.dev' }}
          VITE_ADMIN_PASSWORD: ${{ secrets.VITE_ADMIN_PASSWORD }}
          VITE_STAGE: 'stage2'
          VITE_ENABLE_LOCAL_MODEL: 'true'

      - name: Remove auto-generated wrangler configs
        run: rm -f dist/wrangler.json && rm -rf .wrangler/

      - name: Deploy to Cloudflare Pages (Stage 2)
        uses: nick-fields/retry-action@v3
        with:
          timeout_minutes: 10
          max_attempts: 5
          retry_wait_seconds: 30
          exponential_backoff: true
          command: npx wrangler pages deploy dist --project-name=afia-app-stage2 --branch=local-model
        env:
          CLOUDFLARE_API_TOKEN: ${{ secrets.CLOUDFLARE_API_TOKEN }}
          CLOUDFLARE_ACCOUNT_ID: ${{ secrets.CLOUDFLARE_ACCOUNT_ID }}

      - name: Comment deployment URL
        if: github.event_name == 'push'
        uses: actions/github-script@v7
        with:
          script: |
            github.rest.repos.createCommitComment({
              owner: context.repo.owner,
              repo: context.repo.repo,
              commit_sha: context.sha,
              body: '🚀 **Stage 2 Deployed** (Local Model + LLM Fallback)\n\n✅ Worker: https://afia-worker-stage2.savola.workers.dev\n✅ Pages: https://afia-app-stage2.pages.dev\n\n⚠️ Testing hybrid mode with local model primary and LLM fallback'
            })
