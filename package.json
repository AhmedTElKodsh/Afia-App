    "pptxgenjs": "^4.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.6",
    "react-window": "^2.2.7",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.26.1",
    "@eslint/js": "^9.39.1",
    "@playwright/browser-chromium": "^1.58.2",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
