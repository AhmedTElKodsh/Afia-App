# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Backblaze B2 Storage Configuration
B2_KEY_ID=your-b2-key-id
B2_APPLICATION_KEY=your-b2-application-key
B2_BUCKET_NAME=your-bucket-name
B2_DOWNLOAD_URL=https://f000.backblazeb2.com/file/your-bucket

# Worker API URL (Cloudflare Worker)
# Prefer VITE_PROXY_URL for app -> worker calls. VITE_API_URL is optional legacy alias.
VITE_PROXY_URL=https://afia-worker.savola.workers.dev
VITE_API_URL=https://afia-worker.savola.workers.dev
